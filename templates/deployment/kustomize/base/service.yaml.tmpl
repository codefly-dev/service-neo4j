apiVersion: v1
kind: Service
metadata:
  name: "neo4j-{{ .Service.Name.DNSCase }}"
  namespace: "{{ .Namespace }}"
spec:
  selector:
    app: "neo4j-{{ .Service.Name.DNSCase }}"
  ports:
    - protocol: TCP
      name: bolt
      port: 7687
      targetPort: 7687
    - protocol: TCP
      name: http
      port: 7474
      targetPort: 7474
